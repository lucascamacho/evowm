make_aicc_table <- function(aicc_values) {
data.frame(
model = names(aicc_values),
AICc = as.numeric(aicc_values)
) %>%
arrange(AICc) %>%
mutate(
deltaAICc = AICc - min(AICc, na.rm = TRUE),
weight = exp(-0.5 * deltaAICc) / sum(exp(-0.5 * deltaAICc))
)
}
