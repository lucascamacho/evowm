library(readxl)
library(dplyr)
library(purrr)
library(tidyr)
library(stringr)
library(openxlsx)
library(MASS)
library(readxl)
# carregar datasets
data_c <- readRDS("~/Dropbox/Doc/Data/c_variancia_erro.RDS")
data_p <- readRDS("~/Dropbox/Doc/Data/p_variancia_erro.RDS")
# juntar tudo
data <- bind_rows(data_c, data_p)
# criar identificador de espécie
data <- data %>%
mutate(sp = paste(GENUS, SPECIES))
# lista de espécies
species_list <- unique(data$sp)
species_list
# lista para guardar simulações
error_samples <- list()
for(sp_i in species_list){
# subset da espécie
df_sp <- data %>%
filter(sp == sp_i) %>%
arrange(variavel)
# vetor de variâncias
vars <- df_sp$var_erro
# matriz diagonal de covariâncias
M <- diag(vars)
# vetor de médias
mu <- rep(0, length(vars))
# simulações
sims <- MASS::mvrnorm(
n = 1000,
mu = mu,
Sigma = M
)
# nomear colunas
colnames(sims) <- df_sp$variavel
# transformar em data.frame
sims <- as.data.frame(sims)
# guardar info da espécie
sims$GENUS <- df_sp$GENUS[1]
sims$SPECIES <- df_sp$SPECIES[1]
# reorganizar colunas
sims <- sims %>%
select(GENUS, SPECIES, everything())
# salvar
error_samples[[sp_i]] <- sims
}
