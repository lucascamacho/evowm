data_c <- readRDS("~/Dropbox/Doc/Data/c_variancia_erro.RDS")
data_p <- readRDS("~/Dropbox/Doc/Data/p_variancia_erro.RDS")
# juntar e padronizar nomes
data <- bind_rows(data_c, data_p) %>%
mutate(
GENUS = str_to_title(str_to_lower(GENUS)),
SPECIES = str_to_lower(SPECIES)
)
# criar identificador de espécie
data <- data %>%
mutate(sp = paste(GENUS, SPECIES))
# lista de espécies
species_list <- unique(data$sp)
# lista para guardar simulações
error_samples <- list()
for(sp_i in species_list){
# subset da espécie
df_sp <- data %>%
filter(sp == sp_i) %>%
arrange(variavel)
# vetor de variâncias
vars <- df_sp$var_erro
# matriz diagonal
M <- diag(vars)
# média zero
mu <- rep(0, length(vars))
# gerar simulações
sims <- MASS::mvrnorm(
n = 1000,
mu = mu,
Sigma = M
)
# nomear colunas
colnames(sims) <- df_sp$variavel
# virar data frame
sims <- as.data.frame(sims)
# adicionar info da espécie
sims$GENUS <- df_sp$GENUS[1]
sims$SPECIES <- df_sp$SPECIES[1]
# reorganizar
sims <- sims %>%
dplyr::select(GENUS, SPECIES, everything())
# salvar
error_samples[[sp_i]] <- sims
}
View(error_samples)
# ordem correta das variáveis
traits <- c(
"ISPM","ISNSL","ISPNS","PMZS","PMZI","PMMT",
"NSLNA","NSLZS","NSLZI","NABR","NAFM","NAPNS",
"BRPT","BRAPET","PTFM","PTAPET","PTBA","PTEAM",
"PTZYGO","PTTSP","FMZS","FMMT","ZSZI","ZIMT",
"ZIZYGO","ZITSP","MTPNS","PNSAPET","APETBA",
"APETTS","BAEAM","EAMZYGO","ZYGOTSP","LDAS",
"BRLD","OPILD","PTAS","JPAS","BAOPI"
)
# carregar datasets
data_c <- readRDS("~/Dropbox/Doc/Data/c_variancia_erro.RDS")
data_p <- readRDS("~/Dropbox/Doc/Data/p_variancia_erro.RDS")
# juntar e padronizar nomes
data <- bind_rows(data_c, data_p) %>%
mutate(
GENUS = str_to_title(str_to_lower(GENUS)),
SPECIES = str_to_lower(SPECIES),
variavel = factor(variavel, levels = traits)
)
# identificador de espécie
data <- data %>%
mutate(sp = paste(GENUS, SPECIES))
# lista de espécies
species_list <- unique(data$sp)
# guardar simulações
error_samples <- list()
for(sp_i in species_list){
# subset da espécie
df_sp <- data %>%
filter(sp == sp_i) %>%
arrange(variavel)
# vetor de variâncias
vars <- df_sp$var_erro
# matriz diagonal
M <- diag(vars)
# média zero
mu <- rep(0, length(vars))
# gerar simulações
sims <- MASS::mvrnorm(
n = 1000,
mu = mu,
Sigma = M
)
# nomes das colunas na ordem correta
colnames(sims) <- traits
# virar data.frame
sims <- as.data.frame(sims)
# adicionar info da espécie
sims$GENUS <- df_sp$GENUS[1]
sims$SPECIES <- df_sp$SPECIES[1]
# reorganizar
sims <- sims %>%
dplyr::select(GENUS, SPECIES, all_of(traits))
# salvar
error_samples[[sp_i]] <- sims
}
