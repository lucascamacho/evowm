# M_matrix building from repetibilities
# using vcv matrix
# in catarrhini, repetibility of the specie are the same of the genera
setwd("~/Dropbox/Doc/Code/evowm/R/Scripts/evolvability")
library(openxlsx)
library(dplyr)
library(MASS)
# Read VCV matrices
setwd("~/Dropbox/Doc/Code/evowm/R/Outputs/log/")
temp <- list.files(pattern = "*.csv")
vcv <- lapply(temp, read.csv, header = TRUE, dec = ".", sep = ' ', row.names = 1)
names(vcv) <- gsub(".csv", replacement= "", temp)
medidas <- readRDS("~/Dropbox/Doc/Code/evowm/R/Scripts/evolvability/averages_PCS_autovalues_primates.RDS")
species <- medidas$Species
#
repetibility <- openxlsx::read.xlsx("~/Dropbox/Doc/Data/primates_measures/Repetibility.xlsx")
repetibility$full_species <- paste(repetibility$genus, repetibility$species)
# data frame com nomes das espécies do vcv
vcv_df <- data.frame(
species_vcv = names(vcv)
) %>%
mutate(
genus = sub("_.*", "", species_vcv),
full_species = gsub("_", " ", species_vcv)
)
# join com repetibility para Catarrhini (por gênero)
vcv_cata_rep <- vcv_df %>%
left_join(
repetibility %>%
filter(parvorder == "Catarrhini") %>%
select(genus, vcv_repetibility),
by = "genus"
)
# data frame com nomes das espécies do vcv
vcv_df <- data.frame(
species_vcv = names(vcv)
) %>%
mutate(
genus = sub("_.*", "", species_vcv),
full_species = gsub("_", " ", species_vcv)
)
# join com repetibility para Catarrhini (por gênero)
vcv_cata_rep <- vcv_df %>%
left_join(
repetibility %>%
dplyr::filter(parvorder == "Catarrhini") %>%
dplyr::select(genus, vcv_repetibility),
by = "genus"
)
# join com repetibility para Platyrrhini (por nome completo)
vcv_platy_rep <- vcv_df %>%
left_join(
repetibility %>%
dplyr::filter(parvorder == "Platyrrhini") %>%
dplyr::select(full_species, vcv_repetibility),
by = "full_species"
)
# combina, dando prioridade ao que não é NA
final_df <- vcv_df %>%
left_join(
repetibility %>%
mutate(
species_vcv = gsub(" ", "_", full_species)
) %>%
dplyr::select(species_vcv, vcv_repetibility),
by = "species_vcv"
) %>%
dplyr::filter(!is.na(vcv_repetibility)) %>%
transmute(
species_vcv,
repetibility = vcv_repetibility
)
final_df
vcv_cata_rep
